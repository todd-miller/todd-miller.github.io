---
import { cls } from "@/src/lib/utils";
import { resolveIconUrl } from "@/src/lib/icon";
import type { SkillsShowcase } from "@/src/content";
import SectionHeader from "@/src/components/SectionHeader.astro";

const { heading, subheading, skills } = Astro.props as SkillsShowcase;

const ROW_COUNT = 4;
// pixels per second; negative dir = scroll left (content moves left)
const ROW_SPEED = 10;

const chunk = <T,>(arr: T[], n: number): T[][] => {
  const size = Math.ceil(arr.length / n);
  return Array.from({ length: n }, (_, i) => arr.slice(i * size, (i + 1) * size));
};
const rows = chunk(skills, ROW_COUNT).map((rowSkills, i) => ({
  direction: i % 2 === 0 ? "left" : "right",
  skills: rowSkills,
}));

const duplicate = <T,>(arr: T[]) => [...arr, ...arr, ...arr, ...arr];
---

<section class="group/section mt-20">
  <SectionHeader title={heading} />
  {subheading && <p class="text-white/50 text-sm mb-6">{subheading}</p>}

  <div class="skills-container relative py-2 overflow-hidden">
    {
      rows.map((row) => {
        const skills = duplicate(row.skills);
        return (
          <div
            class="skills-row relative w-full overflow-hidden my-3 group"
            data-direction={row.direction}
          >
            <div class={cls("skills-track flex w-max will-change-transform")}>
              {skills.map((skill) => (
                <a
                  class="skill-card mx-2"
                  href={skill.url ?? "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <div class="skill-inner flex items-center gap-2 px-3 py-1.5 whitespace-nowrap transition-colors">
                    <img
                      src={resolveIconUrl(skill.icon)}
                      alt=""
                      width="20"
                      height="20"
                      loading="lazy"
                    />
                    <span class="text-sm font-medium">{skill.name}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })
    }

    <div class="pointer-events-none absolute left-0 top-0 w-[10%] h-full bg-linear-to-r from-background to-transparent z-10"></div>
    <div class="pointer-events-none absolute right-0 top-0 w-[10%] h-full bg-linear-to-l from-background to-transparent z-10"></div>
  </div>
</section>

<script>
  import { initSkillsMarquee } from "@/src/scripts/skills-marquee";
  initSkillsMarquee(10);
</script>

<style is:global>
  .skills-row {
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
  }
  .skills-row.is-dragging { cursor: grabbing; }
  .skills-row.is-dragging a { pointer-events: none; }
  .skill-card {
    border-radius: 0.375rem;
    background-color: rgb(255 255 255 / 0.05);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    box-shadow: 0 0 0 color-mix(in srgb, var(--color-primary) 0%, transparent);
    transition: border-color 400ms ease-out, box-shadow 400ms ease-out;
  }
  body:has(.job-company:hover) .skill-card {
    border-color: color-mix(in srgb, var(--color-primary) 80%, transparent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--color-primary) 40%, transparent);
  }
  .skill-inner:hover {
    background: rgb(255 255 255 / 0.05);
    border-radius: 0.375rem;
  }
</style>
